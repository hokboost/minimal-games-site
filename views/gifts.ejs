<!DOCTYPE html>
<html lang="<%= lang === 'zh' ? 'zh-CN' : 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
    <style>
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
        background: rgba(0, 0, 0, 0.8);
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        color: #fff;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        border-bottom: 2px solid #00c853;
        padding-bottom: 1rem;
    }

    .header h1 {
        margin: 0;
        color: #00c853;
    }

    .balance-display {
        background: linear-gradient(135deg, #00c853, #00bfa5);
        padding: 1rem 1.5rem;
        border-radius: 10px;
        font-size: 1.2rem;
        font-weight: bold;
    }

    .gifts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .gift-card {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.05));
        border: 2px solid rgba(0, 200, 83, 0.3);
        border-radius: 15px;
        padding: 1.5rem;
        text-align: center;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .gift-card:hover {
        transform: translateY(-5px);
        border-color: #00c853;
        box-shadow: 0 10px 25px rgba(0, 200, 83, 0.3);
    }

    .gift-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
        display: block;
    }

    .gift-name {
        font-size: 1.3rem;
        font-weight: bold;
        color: #00c853;
        margin-bottom: 0.5rem;
    }

    .gift-description {
        color: #ccc;
        margin-bottom: 1rem;
        line-height: 1.4;
        font-size: 0.9rem;
    }

    .gift-price {
        font-size: 1.5rem;
        font-weight: bold;
        color: #ff9800;
        margin-bottom: 1rem;
    }

    .gift-button {
        width: 100%;
        padding: 0.8rem 1.5rem;
        background: linear-gradient(135deg, #00c853, #00bfa5);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .gift-button:hover:not(:disabled) {
        background: linear-gradient(135deg, #00e676, #1de9b6);
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 200, 83, 0.4);
    }

    .gift-button:disabled {
        background: rgba(255, 255, 255, 0.2);
        color: #999;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .nav-links {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .nav-links a {
        color: #00c853;
        text-decoration: none;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        background: rgba(0, 200, 83, 0.1);
        transition: all 0.3s ease;
    }

    .nav-links a:hover {
        background: rgba(0, 200, 83, 0.2);
        transform: translateY(-2px);
    }

    .exchange-history {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.2);
    }

    .history-title {
        color: #00c853;
        margin-bottom: 1rem;
        font-size: 1.3rem;
        font-weight: bold;
    }

    .history-item {
        background: rgba(255, 255, 255, 0.05);
        padding: 1rem;
        margin-bottom: 0.5rem;
        border-radius: 8px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .history-gift {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .history-time {
        color: #999;
        font-size: 0.9rem;
    }

    .loading {
        text-align: center;
        color: #ccc;
        padding: 2rem;
    }

    .quantity-selector {
        margin: 1rem 0;
        text-align: center;
        color: #ccc;
    }

    .quantity-selector label {
        font-weight: bold;
        color: #00c853;
    }

    .quantity-selector input {
        background: rgba(255, 255, 255, 0.1);
        border: 2px solid rgba(0, 200, 83, 0.3);
        color: white;
        text-align: center;
    }

    .quantity-selector input:focus {
        border-color: #00c853;
        outline: none;
        box-shadow: 0 0 10px rgba(0, 200, 83, 0.3);
    }

    .pk-panel {
        margin: 1.5rem 0 2rem;
        background: rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .pk-panel h3 {
        margin: 0;
        color: #ffeb3b;
        font-size: 1.1rem;
    }

    .pk-panel p {
        margin: 0.3rem 0 0;
        color: #ccc;
        font-size: 0.9rem;
    }

    .pk-status {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.9rem;
        color: #9fa8da;
        margin-top: 0.3rem;
    }

    .pk-toggle-btn {
        padding: 0.7rem 1.6rem;
        border-radius: 999px;
        border: none;
        background: linear-gradient(135deg, #ff9800, #ff6f00);
        color: #fff;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .pk-toggle-btn.stop {
        background: linear-gradient(135deg, #ff5252, #ff1744);
    }

    @media (max-width: 768px) {
        .container {
            padding: 1rem;
        }
        
        .header {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
        }
        
        .gifts-grid {
            grid-template-columns: 1fr;
        }
    }
    </style>
</head>
<body data-csrf-token="<%= csrfToken %>">
    <%- include('partials/language-switcher') %>

    <div class="container">
        <div class="header">
            <h1>🎁 <%= lang === 'zh' ? '礼物兑换商店' : 'Gift Exchange Shop' %></h1>
            <div class="balance-display">
                💰 <%= lang === 'zh' ? '电币余额' : 'Coin Balance' %>: <span id="currentBalance"><%= balance || 0 %></span>
            </div>
        </div>

        <div class="pk-panel">
            <div>
                <h3>⚔️ <%= lang === 'zh' ? '自动打PK' : 'Auto PK' %></h3>
                <p><%= lang === 'zh' ? '使用当前绑定房间号启动偷塔脚本' : 'Start the PK script for your bound room ID' %></p>
                <div class="pk-status" id="pkStatusText"><%= lang === 'zh' ? '状态：未运行' : 'Status: Stopped' %></div>
            </div>
            <button class="pk-toggle-btn" id="pkToggleBtn"><%= lang === 'zh' ? '开启自动打PK' : 'Start Auto PK' %></button>
        </div>

        <div class="nav-links">
            <a href="/">🏠 <%= lang === 'zh' ? '返回首页' : 'Home' %></a>
            <a href="/profile">👤 <%= lang === 'zh' ? '个人资料' : 'Profile' %></a>
            <% if (typeof user !== 'undefined' && user && user.is_admin) { %>
                <a href="/admin">⚙️ <%= lang === 'zh' ? '管理后台' : 'Admin' %></a>
            <% } %>
        </div>

        <div class="gifts-grid">
            
            <div class="gift-card">
                <span class="gift-icon">💝</span>
                <div class="gift-name"><%= lang === 'zh' ? '心动盲盒' : 'Mystery Gift Box' %></div>
                <div class="gift-description">
                    <% if (lang === 'zh') { %>
                        随机获得精美礼品，充满惊喜！<br>
                        适合送给心仪的主播
                    <% } else { %>
                        Randomly receive exquisite gifts, full of surprises!<br>
                        Perfect for your favorite streamer
                    <% } %>
                </div>
                <div class="gift-price">150 <%= lang === 'zh' ? '电币/个' : 'coins/each' %></div>
                <div class="quantity-selector">
                    <label><%= lang === 'zh' ? '数量' : 'Quantity' %>:</label>
                    <input type="number" id="heartbox-quantity" min="1" max="100" value="1" style="width: 80px; padding: 5px; margin: 0 10px; border-radius: 4px; border: 1px solid #ccc;">
                    <span><%= lang === 'zh' ? '总价' : 'Total' %>: <span id="heartbox-total">150</span> <%= lang === 'zh' ? '电币' : 'coins' %></span>
                </div>
                <button class="gift-button" data-gift="heartbox" data-cost="150">
                    <%= lang === 'zh' ? '立即兑换' : 'Exchange Now' %>
                </button>
            </div>

            
            <div class="gift-card">
                <span class="gift-icon">🏮</span>
                <div class="gift-name"><%= lang === 'zh' ? '粉丝团灯牌' : 'Fan Light Badge' %></div>
                <div class="gift-description">
                    <% if (lang === 'zh') { %>
                        展示你对主播的支持！<br>
                        成为铁粉的象征
                    <% } else { %>
                        Show your support for the streamer!<br>
                        A symbol of true fans
                    <% } %>
                </div>
                <div class="gift-price">1 <%= lang === 'zh' ? '电币/个' : 'coin/each' %></div>
                <div class="quantity-selector">
                    <label><%= lang === 'zh' ? '数量' : 'Quantity' %>:</label>
                    <input type="number" id="fanlight-quantity" min="1" max="100" value="1" style="width: 80px; padding: 5px; margin: 0 10px; border-radius: 4px; border: 1px solid #ccc;">
                    <span><%= lang === 'zh' ? '总价' : 'Total' %>: <span id="fanlight-total">1</span> <%= lang === 'zh' ? '电币' : 'coins' %></span>
                </div>
                <button class="gift-button" data-gift="fanlight" data-cost="1">
                    <%= lang === 'zh' ? '立即兑换' : 'Exchange Now' %>
                </button>
            </div>

            <div class="gift-card">
                <span class="gift-icon">🛳️</span>
                <div class="gift-name"><%= lang === 'zh' ? '提督一号' : 'Admiral One' %></div>
                <div class="gift-description">
                    <% if (lang === 'zh') { %>
                        高价值礼物，可在背包中发送<br>
                        送给主播提升氛围
                    <% } else { %>
                        High-value gift, can be sent from inventory<br>
                        Boost the room atmosphere
                    <% } %>
                </div>
                <div class="gift-price">19980 <%= lang === 'zh' ? '电币/个' : 'coins/each' %></div>
                <div class="quantity-selector">
                    <label><%= lang === 'zh' ? '数量' : 'Quantity' %>:</label>
                    <input type="number" id="tiedu_one-quantity" min="1" max="100" value="1" style="width: 80px; padding: 5px; margin: 0 10px; border-radius: 4px; border: 1px solid #ccc;">
                    <span><%= lang === 'zh' ? '总价' : 'Total' %>: <span id="tiedu_one-total">19980</span> <%= lang === 'zh' ? '电币' : 'coins' %></span>
                </div>
                <button class="gift-button" data-gift="tiedu_one" data-cost="19980">
                    <%= lang === 'zh' ? '立即兑换' : 'Exchange Now' %>
                </button>
            </div>
        </div>

        <div class="exchange-history">
            <div class="history-title">📜 <%= lang === 'zh' ? '兑换记录' : 'Exchange History' %></div>
            <div id="exchangeHistory">
                <div class="loading"><%= lang === 'zh' ? '正在加载兑换记录...' : 'Loading exchange history...' %></div>
            </div>
        </div>
    </div>

    

    <script src="/socket.io/socket.io.js"></script>
    <script src="/security-alerts.js"></script>
    <script src="/js/gifts.js"></script>
</body>
</html>
